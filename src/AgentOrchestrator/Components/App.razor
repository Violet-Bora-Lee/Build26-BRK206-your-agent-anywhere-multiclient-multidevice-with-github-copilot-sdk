<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                fontFamily: {
                    sans: ['Inter', 'system-ui', 'sans-serif'],
                },
            },
        }
    </script>
    <script>
        // Auto-scrolls an element to its bottom whenever its contents change,
        // but only if the user was already at (or near) the bottom beforehand.
        window.setupAutoScrollEnd = function (el) {
            if (!el || el.__autoScrollSet) return;
            el.__autoScrollSet = true;

            const threshold = 24; // px of slack
            let stickToBottom = true;

            const isAtBottom = () =>
                el.scrollHeight - el.scrollTop - el.clientHeight <= threshold;

            el.addEventListener('scroll', () => {
                stickToBottom = isAtBottom();
            }, { passive: true });

            const obs = new MutationObserver(() => {
                if (stickToBottom) {
                    el.scrollTo({ top: el.scrollHeight, behavior: 'smooth' });
                }
            });
            obs.observe(el, { childList: true, subtree: true, characterData: true });
        };

        window.setupResizableSidebar = function (sidebar) {
            if (!sidebar) return;
            const savedWidth = Number(localStorage.getItem('dashboardSidebarWidth'));
            if (Number.isFinite(savedWidth) && savedWidth > 0) {
                sidebar.style.width = `${savedWidth}px`;
            }
        };

        window.startSidebarResize = function (event, sidebar) {
            if (!sidebar) return;
            event.preventDefault();

            const minSidebarWidth = 320;
            const minMainWidth = 560;
            const maxSidebarWidth = () => Math.max(minSidebarWidth, window.innerWidth - minMainWidth);

            const resize = (clientX) => {
                const width = Math.min(Math.max(window.innerWidth - clientX, minSidebarWidth), maxSidebarWidth());
                sidebar.style.width = `${width}px`;
                localStorage.setItem('dashboardSidebarWidth', String(width));
            };

            document.body.style.cursor = 'col-resize';
            document.body.style.userSelect = 'none';
            resize(event.clientX);

            const onPointerMove = (moveEvent) => resize(moveEvent.clientX);
            const onPointerUp = () => {
                document.body.style.cursor = '';
                document.body.style.userSelect = '';
                window.removeEventListener('pointermove', onPointerMove);
                window.removeEventListener('pointerup', onPointerUp);
                window.removeEventListener('pointercancel', onPointerUp);
            };

            window.addEventListener('pointermove', onPointerMove);
            window.addEventListener('pointerup', onPointerUp);
            window.addEventListener('pointercancel', onPointerUp);
        };
    </script>
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["AgentOrchestrator.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body class="bg-white text-slate-800 antialiased">
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
